[sub_resource type="Resource" id="node_2"]
script = ExtResource("2_node")
node_id = "s3_body1"
speaker = "system"
text = "死者约四十三四岁，中等身材，黑鬈发，短硬胡子，穿背心与黑呢礼服，身旁有整洁礼帽。紧握双拳、两臂伸开、双腿交叠，临死前有过痛苦挣扎，脸上露出忿恨恐怖的神情。"
mood = "neutral"
trigger = "auto"
next_nodes = ["s3_body2"]
difficulty_filter = 0
verify_filter = ""
exploration_step = 1
is_step_entry = true
stage_direction = "特写"
